# ============================================================================
# VARIÁVEIS DE AMBIENTE - Template
# ============================================================================
# INSTRUÇÕES: Copie este arquivo para .env e preencha os valores reais
#
# IMPORTANTE: Arquivo .env contém dados sensíveis - NUNCA fazer commit!
#             Adicione ".env" ao arquivo .gitignore
# ============================================================================

# Conexão MongoDB
# Para MongoDB local:
#   mongodb://localhost:27017
# 
# Para MongoDB Atlas (cloud):
#   mongodb+srv://usuario:senha@cluster-xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb://localhost:27017

# Nome do banco de dados no MongoDB
MONGODB_DBNAME=filmes_db

# Porta do servidor TCP
PORT=8080

# ============================================================================
# Exemplos de configuração
# ============================================================================

# EXEMPLO 1: MongoDB Local
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DBNAME=filmes_db
# PORT=8080

# EXEMPLO 2: MongoDB Atlas
# MONGODB_URL=mongodb+srv://usuario:senha@cluster-abcd1234.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DBNAME=filmes_producao
# PORT=8080

# EXEMPLO 3: MongoDB em container Docker
# MONGODB_URL=mongodb://mongodb-container:27017
# MONGODB_DBNAME=filmes_db
# PORT=8080
